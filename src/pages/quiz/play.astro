---
import Layout from '../../layouts/Layout.astro';
import staticQuiz from '../../data/quiz/static-quiz-v1.json';

const questionCount = staticQuiz.questions.length;
---

<Layout title="Quiz Player Join (MVP Placeholder)">
  <main class="page">
    <h1>Join Room (Placeholder)</h1>
    <p>This is the player join screen for the quiz MVP.</p>
    <p><strong>Loaded quiz:</strong> {staticQuiz.title}</p>
    <p><strong>Question count:</strong> {questionCount}</p>
    <p><strong>Default timer:</strong> {staticQuiz.timeLimitSecDefault}s</p>
    <ul>
      <li>Enter room code</li>
      <li>Enter display name</li>
      <li>Join lobby</li>
    </ul>
    <p><a href="/game">Back to Game Center</a></p>
  </main>
</Layout>

<style>
  .page {
    max-width: 720px;
    margin: 3rem auto;
    padding: 1.5rem;
    background: #fff;
    border-radius: 12px;
  }
</style>
