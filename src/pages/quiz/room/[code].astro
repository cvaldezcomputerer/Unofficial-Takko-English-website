---
import Layout from '../../../layouts/Layout.astro';

export const prerender = false;

const { code } = Astro.params;
---

<Layout title={`Quiz Room ${code ?? ''} (MVP Placeholder)`}>
  <main class="page">
    <h1>Room {code}</h1>
    <p>This route is the live room shell for host/player state.</p>
    <ul>
      <li>Waiting lobby</li>
      <li>Question phase</li>
      <li>Results phase</li>
    </ul>
    <p><a href="/game">Back to Game Center</a></p>
  </main>
</Layout>

<style>
  .page {
    max-width: 720px;
    margin: 3rem auto;
    padding: 1.5rem;
    background: #fff;
    border-radius: 12px;
  }
</style>
