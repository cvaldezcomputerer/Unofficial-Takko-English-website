---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Quiz Host (MVP Placeholder)">
  <main class="page">
    <h1>Host Room (Placeholder)</h1>
    <p>This is the host setup screen for the quiz MVP.</p>
    <ul>
      <li>Create room code</li>
      <li>Show lobby players</li>
      <li>Start game</li>
    </ul>
    <p><a href="/game">Back to Game Center</a></p>
  </main>
</Layout>

<style>
  .page {
    max-width: 720px;
    margin: 3rem auto;
    padding: 1.5rem;
    background: #fff;
    border-radius: 12px;
  }
</style>
