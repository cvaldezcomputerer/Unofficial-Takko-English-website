---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import T from '../components/T.astro';
---

<Layout title="Takko Town English">
  <div class="banner">
    <div class="banner-content">
      <h1>Takko Taco</h1>
      <p data-translate="subtitle">
        <T>
          <span slot="en">Web Development & Japanese Learning</span>
          <span slot="ja">ウェブ開発と日本語学習</span>
        </T>
      </p>
    </div>
  </div>

  <Navbar />

  <div class="container">
    <div class="title-section">
      <h2 data-translate="about">
        <T>
          <span slot="en">ABOUT</span>
          <span slot="ja">アバウト</span>
        </T>
      </h2>
    </div>

    <main class="main-content">
      <aside class="sidebar">
        <div class="profile-box">
          <img src="/images/hi.png" alt="Cristian Valdez" />
        </div>
        
        <div class="links-box">
          <h2>
            <T>
              <span slot="en">LINKS</span>
              <span slot="ja">リンク</span>
            </T>
          </h2>
          <a href="https://youtube.com" class="link youtube" target="_blank" rel="noopener noreferrer">
             <i class="fab fa-youtube"></i> YouTube
          </a>
          <a href="https://quizlet.com" class="link quizlet" target="_blank" rel="noopener noreferrer">
             <i class="fas fa-sticky-note"></i> Quizlet
          </a>
        </div>
      </aside>

      <section class="content">
        <h2>
          <T>
            <span slot="en">Hello!</span>
            <span slot="ja">こんにちは！</span>
          </T>
        </h2>
        <h3>
          <T>
            <span slot="en">Welcome to my Website.</span>
            <span slot="ja">私のウェブサイトへようこそ。</span>
          </T>
        </h3>
        <p>
          <T>
            <span slot="en">My name is Cristian Valdez. I created this website to share my passion for coding and languages.</span>
            <span slot="ja">クリスティアン・バルデスと申します。コーディングと言語への情熱を共有するためにこのウェブサイトを作成しました。</span>
          </T>
        </p>
        <p>
          <T>
            <span slot="en">Please feel free to look around and contact me if you have any questions!</span>
            <span slot="ja">ご自由にご覧ください。ご質問があればお気軽にお問い合わせください！</span>
          </T>
        </p>
      </section>
    </main>
  </div>
</Layout>

<style>
  /* Banner */
  .banner {
    width: 100%;
    height: 320px;
    background-image: url("/images/yo2.jpg");
    background-size: cover;
    background-position: center;
    position: relative;
    margin-bottom: 1rem; /* Space before navbar */
  }

  .banner-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-banner-overlay);
    padding: 2rem 3.5rem;
    border-radius: 20px;
    text-align: center;
    color: var(--color-white);
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .banner-content h1 {
    margin: 0;
    font-size: 3.5rem;
    font-weight: 700;
  }

  .banner-content p {
    margin: 0.8rem 0 0;
    font-size: 1.3rem;
    opacity: 0.95;
  }

  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Title Section */
  .title-section {
    background: var(--color-primary);
    color: var(--color-white);
    text-align: center;
    padding: 2.5rem;
    margin: 3rem 0;
    border-radius: 25px;
    box-shadow: 0 8px 20px rgba(85, 113, 83, 0.2);
  }

  .title-section h2 {
    margin: 0;
    font-size: 2.8rem;
    letter-spacing: 4px;
  }

  /* Main Content Layout */
  .main-content {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 4rem;
    margin-bottom: 5rem;
  }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .profile-box {
    background: var(--color-white);
    padding: 1.5rem;
    border-radius: 25px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    border: 2px solid var(--color-beige);
  }

  .profile-box img {
    width: 100%;
    height: auto;
    border-radius: 18px;
    border: 4px solid var(--color-beige);
  }

  .links-box {
    background: var(--color-white);
    padding: 2rem;
    border-radius: 25px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    border: 2px solid var(--color-beige);
  }

  .links-box h2 {
    color: var(--color-primary);
    border-bottom: 3px solid var(--color-beige);
    padding-bottom: 0.8rem;
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
  }

  .link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: bold;
    margin-bottom: 0.8rem;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .link:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 12px rgba(0,0,0,0.1);
  }

  .link.youtube {
    background: #ff0000;
    color: white;
  }

  .link.quizlet {
    background: #4257b2;
    color: white;
  }

  /* Content Section */
  .content {
    background: var(--color-white);
    padding: 3.5rem;
    border-radius: 30px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.04);
    border: 2px solid var(--color-beige);
  }

  .content h2 {
    color: var(--color-primary);
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .content h3 {
    color: var(--color-text);
    font-weight: 500;
    margin-bottom: 2rem;
    font-size: 1.4rem;
    opacity: 0.8;
  }

  .content p {
    margin-bottom: 1.5rem;
    line-height: 1.9;
    font-size: 1.1rem;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .main-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .sidebar {
      order: 2;
    }
    
    .content {
      order: 1;
    }

    .banner {
      height: 280px;
    }

    .banner-content h1 {
      font-size: 2.5rem;
    }
  }
</style>