---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import LetterFlipGame from "../components/LetterFlipGame.astro";
---

<Layout title="Letter Flip Game">
  <div class="letter-game-page">
    <Navbar />

    <main>
        <LetterFlipGame />
    </main>
  </div>
</Layout>

<style>
  .letter-game-page {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding-bottom: 2rem;
  }
</style>